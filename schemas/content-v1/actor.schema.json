{
  "$defs": {
    "ActorDamageType": {
      "enum": [
        "physical",
        "acid",
        "electricity",
        "fire",
        "cold",
        "poison"
      ],
      "type": "string"
    },
    "ActorRole": {
      "enum": [
        "player",
        "monster"
      ],
      "type": "string"
    },
    "MeleeBlowDefinition": {
      "additionalProperties": false,
      "properties": {
        "damageDice": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageSides": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageType": {
          "$ref": "#/$defs/ActorDamageType",
          "default": "physical"
        },
        "methodId": {
          "type": "string"
        },
        "toHit": {
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "methodId",
        "toHit",
        "damageDice",
        "damageSides"
      ],
      "type": "object"
    },
    "MeleeRoutineDefinition": {
      "additionalProperties": false,
      "properties": {
        "blows": {
          "items": {
            "$ref": "#/$defs/MeleeBlowDefinition"
          },
          "type": "array"
        }
      },
      "required": [
        "blows"
      ],
      "type": "object"
    }
  },
  "$id": "https://raw.githubusercontent.com/UncleFvcker/RoguelikeFansBand-Rewrite/main/schemas/content-v1/actor.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "attack": {
      "format": "int32",
      "type": "integer"
    },
    "bashPower": {
      "default": 0,
      "format": "int32",
      "type": "integer"
    },
    "carriedLootTableId": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "carryCapacityTenthsPound": {
      "default": 0,
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "damageDice": {
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "damageSides": {
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "damageType": {
      "$ref": "#/$defs/ActorDamageType",
      "default": "physical"
    },
    "defense": {
      "format": "int32",
      "type": "integer"
    },
    "descriptionKey": {
      "type": "string"
    },
    "digSkill": {
      "default": 0,
      "format": "int32",
      "type": "integer"
    },
    "disarmSkill": {
      "default": 0,
      "format": "int32",
      "type": "integer"
    },
    "doorSkill": {
      "default": 0,
      "format": "int32",
      "type": "integer"
    },
    "formatVersion": {
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "glyph": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "level": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "lootTableId": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "maxHp": {
      "format": "int32",
      "type": "integer"
    },
    "meleeRoutine": {
      "anyOf": [
        {
          "$ref": "#/$defs/MeleeRoutineDefinition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "nameKey": {
      "type": "string"
    },
    "role": {
      "$ref": "#/$defs/ActorRole"
    },
    "searchSkill": {
      "default": 0,
      "format": "int32",
      "type": "integer"
    },
    "speed": {
      "default": 110,
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "formatVersion",
    "id",
    "role",
    "nameKey",
    "descriptionKey",
    "glyph",
    "level",
    "maxHp",
    "attack",
    "defense",
    "damageDice",
    "damageSides",
    "tags"
  ],
  "title": "ActorDefinition",
  "type": "object"
}
