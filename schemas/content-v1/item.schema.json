{
  "$defs": {
    "ActorDamageType": {
      "enum": [
        "physical",
        "acid",
        "electricity",
        "fire",
        "cold",
        "poison"
      ],
      "type": "string"
    },
    "AttackProfileDefinition": {
      "additionalProperties": false,
      "properties": {
        "attacks": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageDice": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageSides": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageType": {
          "$ref": "#/$defs/ActorDamageType",
          "default": "physical"
        },
        "toDamage": {
          "format": "int32",
          "type": "integer"
        },
        "toHit": {
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "attacks",
        "toHit",
        "toDamage",
        "damageDice",
        "damageSides"
      ],
      "type": "object"
    },
    "ProjectileProfileDefinition": {
      "additionalProperties": false,
      "properties": {
        "ammoKindId": {
          "type": "string"
        },
        "damageDice": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageSides": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageType": {
          "$ref": "#/$defs/ActorDamageType",
          "default": "physical"
        },
        "range": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "toDamage": {
          "format": "int32",
          "type": "integer"
        },
        "toHit": {
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "range",
        "toHit",
        "toDamage",
        "damageDice",
        "damageSides",
        "ammoKindId"
      ],
      "type": "object"
    },
    "StatModifiers": {
      "additionalProperties": false,
      "properties": {
        "attack": {
          "default": 0,
          "format": "int32",
          "type": "integer"
        },
        "defense": {
          "default": 0,
          "format": "int32",
          "type": "integer"
        },
        "maxHp": {
          "default": 0,
          "format": "int32",
          "type": "integer"
        }
      },
      "type": "object"
    },
    "ThrowProfileDefinition": {
      "additionalProperties": false,
      "properties": {
        "damageDice": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageSides": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "damageType": {
          "$ref": "#/$defs/ActorDamageType",
          "default": "physical"
        },
        "toDamage": {
          "format": "int32",
          "type": "integer"
        },
        "toHit": {
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "toHit",
        "toDamage",
        "damageDice",
        "damageSides"
      ],
      "type": "object"
    }
  },
  "$id": "https://raw.githubusercontent.com/UncleFvcker/RoguelikeFansBand-Rewrite/main/schemas/content-v1/item.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "breakChancePercent": {
      "default": 0,
      "format": "uint8",
      "maximum": 255,
      "minimum": 0,
      "type": "integer"
    },
    "descriptionKey": {
      "type": "string"
    },
    "equipmentSlot": {
      "default": null,
      "type": [
        "string",
        "null"
      ]
    },
    "formatVersion": {
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    },
    "glyph": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "maxStack": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "meleeProfile": {
      "anyOf": [
        {
          "$ref": "#/$defs/AttackProfileDefinition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "modifiers": {
      "$ref": "#/$defs/StatModifiers",
      "default": {
        "attack": 0,
        "defense": 0,
        "maxHp": 0
      }
    },
    "nameKey": {
      "type": "string"
    },
    "projectileProfile": {
      "anyOf": [
        {
          "$ref": "#/$defs/ProjectileProfileDefinition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "throwProfile": {
      "anyOf": [
        {
          "$ref": "#/$defs/ThrowProfileDefinition"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "weightTenthsPound": {
      "format": "uint16",
      "maximum": 65535,
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "$schema",
    "formatVersion",
    "id",
    "nameKey",
    "descriptionKey",
    "glyph",
    "weightTenthsPound",
    "maxStack",
    "tags"
  ],
  "title": "ItemDefinition",
  "type": "object"
}
