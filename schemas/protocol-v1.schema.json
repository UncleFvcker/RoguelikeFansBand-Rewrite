{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtocolSchemaV1",
  "description": "Schema bundle for the types crossing the CoreTransport boundary.",
  "type": "object",
  "properties": {
    "command": {
      "$ref": "#/$defs/GameCommandEnvelope"
    },
    "snapshot": {
      "$ref": "#/$defs/GameSnapshot"
    },
    "update": {
      "$ref": "#/$defs/GameUpdate"
    }
  },
  "required": [
    "command",
    "snapshot",
    "update"
  ],
  "$defs": {
    "AttackProfileDto": {
      "type": "object",
      "properties": {
        "attacks": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "damage": {
          "$ref": "#/$defs/DamageDiceDto"
        },
        "sourceItemId": {
          "type": [
            "string",
            "null"
          ]
        },
        "toDamage": {
          "type": "integer",
          "format": "int32"
        },
        "toHit": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "attacks",
        "toHit",
        "toDamage",
        "damage"
      ]
    },
    "CellDto": {
      "type": "object",
      "properties": {
        "actorId": {
          "type": [
            "string",
            "null"
          ]
        },
        "itemId": {
          "type": [
            "string",
            "null"
          ]
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "terrainId": {
          "type": "string"
        }
      },
      "required": [
        "position",
        "terrainId"
      ]
    },
    "CellLightDto": {
      "type": "object",
      "properties": {
        "color": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "intensity": {
          "type": "integer",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        }
      },
      "required": [
        "color",
        "intensity"
      ]
    },
    "CellVisualDto": {
      "type": "object",
      "properties": {
        "light": {
          "$ref": "#/$defs/CellLightDto"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "visibility": {
          "$ref": "#/$defs/VisibilityState"
        }
      },
      "required": [
        "position",
        "visibility",
        "light"
      ]
    },
    "ContentVisualDto": {
      "type": "object",
      "properties": {
        "glyph": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "glyph"
      ]
    },
    "DamageDiceDto": {
      "type": "object",
      "properties": {
        "damageType": {
          "$ref": "#/$defs/DamageTypeDto",
          "default": "physical"
        },
        "dice": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "sides": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "dice",
        "sides"
      ]
    },
    "DamageResolutionDto": {
      "type": "object",
      "properties": {
        "armorReduction": {
          "type": "integer",
          "format": "int32"
        },
        "damageType": {
          "$ref": "#/$defs/DamageTypeDto"
        },
        "finalDamage": {
          "type": "integer",
          "format": "int32"
        },
        "rawDamage": {
          "type": "integer",
          "format": "int32"
        },
        "resistance": {
          "$ref": "#/$defs/ResistanceLevelDto"
        },
        "resistanceAdjustment": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "rawDamage",
        "armorReduction",
        "resistanceAdjustment",
        "finalDamage",
        "damageType",
        "resistance"
      ]
    },
    "DamageTypeDto": {
      "type": "string",
      "enum": [
        "physical",
        "acid",
        "electricity",
        "fire",
        "cold",
        "poison"
      ]
    },
    "Direction": {
      "type": "string",
      "enum": [
        "north",
        "north-east",
        "east",
        "south-east",
        "south",
        "south-west",
        "west",
        "north-west"
      ]
    },
    "EntityDto": {
      "type": "object",
      "properties": {
        "armorClass": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "attack": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "defense": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "energyNeed": {
          "type": "integer",
          "format": "int32",
          "default": 100
        },
        "hp": {
          "type": "integer",
          "format": "int32"
        },
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "maxHp": {
          "type": "integer",
          "format": "int32"
        },
        "meleeDamage": {
          "$ref": "#/$defs/DamageDiceDto",
          "default": {
            "damageType": "physical",
            "dice": 0,
            "sides": 0
          }
        },
        "meleeProfile": {
          "$ref": "#/$defs/AttackProfileDto",
          "default": {
            "attacks": 1,
            "damage": {
              "damageType": "physical",
              "dice": 0,
              "sides": 0
            },
            "toDamage": 0,
            "toHit": 0
          }
        },
        "meleeRoutine": {
          "$ref": "#/$defs/MeleeRoutineDto",
          "default": {
            "blows": []
          }
        },
        "meleeSkill": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "speed": {
          "type": "integer",
          "format": "uint16",
          "default": 110,
          "maximum": 65535,
          "minimum": 0
        },
        "statuses": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/StatusDto"
          }
        }
      },
      "required": [
        "id",
        "kindId",
        "position",
        "hp",
        "maxHp"
      ]
    },
    "EquipmentItemDto": {
      "type": "object",
      "properties": {
        "displayNameKey": {
          "type": "string",
          "default": ""
        },
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "knowledge": {
          "$ref": "#/$defs/ItemKnowledgeDto",
          "default": "aware"
        },
        "meleeProfile": {
          "anyOf": [
            {
              "$ref": "#/$defs/AttackProfileDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "modifiers": {
          "$ref": "#/$defs/StatModifiersDto",
          "default": {
            "attack": 0,
            "defense": 0,
            "maxHp": 0
          }
        },
        "projectileProfile": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProjectileProfileDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "quantity": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "slotId": {
          "type": "string"
        },
        "throwProfile": {
          "anyOf": [
            {
              "$ref": "#/$defs/ThrowProfileDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "weightTenthsPound": {
          "type": "integer",
          "format": "uint16",
          "default": 0,
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "id",
        "kindId",
        "quantity",
        "slotId"
      ]
    },
    "GameCommand": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "itemIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "type": {
              "type": "string",
              "const": "drop"
            }
          },
          "required": [
            "type",
            "itemIds"
          ]
        },
        {
          "type": "object",
          "properties": {
            "itemId": {
              "type": "string"
            },
            "quantity": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            },
            "type": {
              "type": "string",
              "const": "drop-quantity"
            }
          },
          "required": [
            "type",
            "itemId",
            "quantity"
          ]
        },
        {
          "type": "object",
          "properties": {
            "itemId": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "equip"
            }
          },
          "required": [
            "type",
            "itemId"
          ]
        },
        {
          "type": "object",
          "properties": {
            "direction": {
              "$ref": "#/$defs/Direction"
            },
            "type": {
              "type": "string",
              "const": "fire"
            }
          },
          "required": [
            "type",
            "direction"
          ]
        },
        {
          "type": "object",
          "properties": {
            "target": {
              "$ref": "#/$defs/TargetSelection"
            },
            "type": {
              "type": "string",
              "const": "fire-target"
            }
          },
          "required": [
            "type",
            "target"
          ]
        },
        {
          "type": "object",
          "properties": {
            "direction": {
              "$ref": "#/$defs/Direction"
            },
            "type": {
              "type": "string",
              "const": "move"
            }
          },
          "required": [
            "type",
            "direction"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "pick-up"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "direction": {
              "$ref": "#/$defs/Direction"
            },
            "itemId": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "throw"
            }
          },
          "required": [
            "type",
            "itemId",
            "direction"
          ]
        },
        {
          "type": "object",
          "properties": {
            "itemId": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "use-item"
            }
          },
          "required": [
            "type",
            "itemId"
          ]
        },
        {
          "type": "object",
          "properties": {
            "slotId": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "unequip"
            }
          },
          "required": [
            "type",
            "slotId"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "wait"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
    "GameCommandEnvelope": {
      "type": "object",
      "properties": {
        "command": {
          "$ref": "#/$defs/GameCommand"
        },
        "commandSeq": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "expectedRevision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "commandSeq",
        "expectedRevision",
        "command"
      ]
    },
    "GameEventDto": {
      "type": "object",
      "properties": {
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string"
        },
        "messageKey": {
          "type": "string"
        },
        "outcome": {
          "anyOf": [
            {
              "$ref": "#/$defs/GameEventOutcomeDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "trace": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProjectileTraceDto"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "kind",
        "messageKey",
        "args"
      ]
    },
    "GameEventOutcomeDto": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "resolution": {
              "$ref": "#/$defs/DamageResolutionDto"
            },
            "type": {
              "type": "string",
              "const": "damage"
            }
          },
          "required": [
            "type",
            "resolution"
          ]
        },
        {
          "type": "object",
          "properties": {
            "resolution": {
              "$ref": "#/$defs/DamageResolutionDto"
            },
            "type": {
              "type": "string",
              "const": "death"
            }
          },
          "required": [
            "type",
            "resolution"
          ]
        },
        {
          "type": "object",
          "properties": {
            "resolution": {
              "$ref": "#/$defs/HealingResolutionDto"
            },
            "type": {
              "type": "string",
              "const": "heal"
            }
          },
          "required": [
            "type",
            "resolution"
          ]
        }
      ]
    },
    "GameSnapshot": {
      "type": "object",
      "properties": {
        "cells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CellDto"
          }
        },
        "contentHash": {
          "type": "string"
        },
        "contentId": {
          "type": "string"
        },
        "contentVisuals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContentVisualDto"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDto"
          }
        },
        "equipment": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/EquipmentItemDto"
          }
        },
        "height": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InventoryItemDto"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemDto"
          }
        },
        "lastCommandSeq": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "player": {
          "$ref": "#/$defs/PlayerDto"
        },
        "protocolVersion": {
          "type": "string"
        },
        "revision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "stateHash": {
          "type": "string"
        },
        "turn": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "visualCells": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/CellVisualDto"
          }
        },
        "width": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "worldId": {
          "type": "string"
        },
        "worldTick": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        }
      },
      "required": [
        "protocolVersion",
        "revision",
        "turn",
        "lastCommandSeq",
        "width",
        "height",
        "cells",
        "player",
        "entities",
        "items",
        "inventory",
        "contentId",
        "contentHash",
        "contentVisuals",
        "worldId",
        "stateHash"
      ]
    },
    "GameUpdate": {
      "type": "object",
      "properties": {
        "baseRevision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "changedCells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CellDto"
          }
        },
        "changedVisualCells": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/CellVisualDto"
          }
        },
        "commandSeq": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDto"
          }
        },
        "equipment": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/EquipmentItemDto"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GameEventDto"
          }
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InventoryItemDto"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemDto"
          }
        },
        "player": {
          "$ref": "#/$defs/PlayerDto"
        },
        "removedEntities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "stateHash": {
          "type": "string"
        },
        "turn": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "worldTick": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        }
      },
      "required": [
        "baseRevision",
        "revision",
        "turn",
        "commandSeq",
        "events",
        "changedCells",
        "player",
        "entities",
        "items",
        "inventory",
        "removedEntities",
        "stateHash"
      ]
    },
    "HealingResolutionDto": {
      "type": "object",
      "properties": {
        "applied": {
          "type": "integer",
          "format": "int32"
        },
        "requested": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "requested",
        "applied"
      ]
    },
    "InventoryItemDto": {
      "type": "object",
      "properties": {
        "displayNameKey": {
          "type": "string",
          "default": ""
        },
        "equipmentSlot": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "knowledge": {
          "$ref": "#/$defs/ItemKnowledgeDto",
          "default": "aware"
        },
        "meleeProfile": {
          "anyOf": [
            {
              "$ref": "#/$defs/AttackProfileDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "modifiers": {
          "$ref": "#/$defs/StatModifiersDto",
          "default": {
            "attack": 0,
            "defense": 0,
            "maxHp": 0
          }
        },
        "projectileProfile": {
          "anyOf": [
            {
              "$ref": "#/$defs/ProjectileProfileDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "quantity": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "throwProfile": {
          "anyOf": [
            {
              "$ref": "#/$defs/ThrowProfileDto"
            },
            {
              "type": "null"
            }
          ]
        },
        "usable": {
          "type": "boolean",
          "default": false
        },
        "weightTenthsPound": {
          "type": "integer",
          "format": "uint16",
          "default": 0,
          "maximum": 65535,
          "minimum": 0
        }
      },
      "required": [
        "id",
        "kindId",
        "quantity"
      ]
    },
    "ItemDto": {
      "type": "object",
      "properties": {
        "displayNameKey": {
          "type": "string",
          "default": ""
        },
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "knowledge": {
          "$ref": "#/$defs/ItemKnowledgeDto",
          "default": "aware"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "quantity": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "kindId",
        "position",
        "quantity"
      ]
    },
    "ItemKnowledgeDto": {
      "type": "string",
      "enum": [
        "unknown",
        "tried",
        "aware"
      ]
    },
    "MeleeBlowDto": {
      "type": "object",
      "properties": {
        "damage": {
          "$ref": "#/$defs/DamageDiceDto"
        },
        "methodId": {
          "type": "string"
        },
        "toHit": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "methodId",
        "toHit",
        "damage"
      ]
    },
    "MeleeRoutineDto": {
      "type": "object",
      "properties": {
        "blows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MeleeBlowDto"
          }
        }
      },
      "required": [
        "blows"
      ]
    },
    "PlayerDto": {
      "type": "object",
      "properties": {
        "armorClass": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "attack": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "baseAttack": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "baseDefense": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "baseMaxHp": {
          "type": "integer",
          "format": "int32",
          "default": 0
        },
        "carriedWeightTenthsPound": {
          "type": "integer",
          "format": "uint32",
          "default": 0,
          "minimum": 0
        },
        "carryCapacityTenthsPound": {
          "type": "integer",
