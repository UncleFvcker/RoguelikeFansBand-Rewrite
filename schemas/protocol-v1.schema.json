{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProtocolSchemaV1",
  "description": "Schema bundle for the types crossing the CoreTransport boundary.",
  "type": "object",
  "properties": {
    "command": {
      "$ref": "#/$defs/GameCommandEnvelope"
    },
    "snapshot": {
      "$ref": "#/$defs/GameSnapshot"
    },
    "update": {
      "$ref": "#/$defs/GameUpdate"
    }
  },
  "required": [
    "command",
    "snapshot",
    "update"
  ],
  "$defs": {
    "CellDto": {
      "type": "object",
      "properties": {
        "actorId": {
          "type": [
            "string",
            "null"
          ]
        },
        "itemId": {
          "type": [
            "string",
            "null"
          ]
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "terrainId": {
          "type": "string"
        }
      },
      "required": [
        "position",
        "terrainId"
      ]
    },
    "CellLightDto": {
      "type": "object",
      "properties": {
        "color": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "intensity": {
          "type": "integer",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0
        }
      },
      "required": [
        "color",
        "intensity"
      ]
    },
    "CellVisualDto": {
      "type": "object",
      "properties": {
        "light": {
          "$ref": "#/$defs/CellLightDto"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "visibility": {
          "$ref": "#/$defs/VisibilityState"
        }
      },
      "required": [
        "position",
        "visibility",
        "light"
      ]
    },
    "ContentVisualDto": {
      "type": "object",
      "properties": {
        "glyph": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "glyph"
      ]
    },
    "Direction": {
      "type": "string",
      "enum": [
        "north",
        "north-east",
        "east",
        "south-east",
        "south",
        "south-west",
        "west",
        "north-west"
      ]
    },
    "EntityDto": {
      "type": "object",
      "properties": {
        "hp": {
          "type": "integer",
          "format": "int32"
        },
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "maxHp": {
          "type": "integer",
          "format": "int32"
        },
        "position": {
          "$ref": "#/$defs/Position"
        }
      },
      "required": [
        "id",
        "kindId",
        "position",
        "hp",
        "maxHp"
      ]
    },
    "GameCommand": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "direction": {
              "$ref": "#/$defs/Direction"
            },
            "type": {
              "type": "string",
              "const": "move"
            }
          },
          "required": [
            "type",
            "direction"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "pick-up"
            }
          },
          "required": [
            "type"
          ]
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "wait"
            }
          },
          "required": [
            "type"
          ]
        }
      ]
    },
    "GameCommandEnvelope": {
      "type": "object",
      "properties": {
        "command": {
          "$ref": "#/$defs/GameCommand"
        },
        "commandSeq": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "expectedRevision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "commandSeq",
        "expectedRevision",
        "command"
      ]
    },
    "GameEventDto": {
      "type": "object",
      "properties": {
        "args": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "kind": {
          "type": "string"
        },
        "messageKey": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "messageKey",
        "args"
      ]
    },
    "GameSnapshot": {
      "type": "object",
      "properties": {
        "cells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CellDto"
          }
        },
        "contentHash": {
          "type": "string"
        },
        "contentId": {
          "type": "string"
        },
        "contentVisuals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContentVisualDto"
          }
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDto"
          }
        },
        "height": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InventoryItemDto"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemDto"
          }
        },
        "lastCommandSeq": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "player": {
          "$ref": "#/$defs/PlayerDto"
        },
        "protocolVersion": {
          "type": "string"
        },
        "revision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "stateHash": {
          "type": "string"
        },
        "turn": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "visualCells": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/CellVisualDto"
          }
        },
        "width": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "worldId": {
          "type": "string"
        }
      },
      "required": [
        "protocolVersion",
        "revision",
        "turn",
        "lastCommandSeq",
        "width",
        "height",
        "cells",
        "player",
        "entities",
        "items",
        "inventory",
        "contentId",
        "contentHash",
        "contentVisuals",
        "worldId",
        "stateHash"
      ]
    },
    "GameUpdate": {
      "type": "object",
      "properties": {
        "baseRevision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "changedCells": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CellDto"
          }
        },
        "changedVisualCells": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/CellVisualDto"
          }
        },
        "commandSeq": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "entities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EntityDto"
          }
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GameEventDto"
          }
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InventoryItemDto"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ItemDto"
          }
        },
        "player": {
          "$ref": "#/$defs/PlayerDto"
        },
        "removedEntities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "revision": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "stateHash": {
          "type": "string"
        },
        "turn": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "baseRevision",
        "revision",
        "turn",
        "commandSeq",
        "events",
        "changedCells",
        "player",
        "entities",
        "items",
        "inventory",
        "removedEntities",
        "stateHash"
      ]
    },
    "InventoryItemDto": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "quantity": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "kindId",
        "quantity"
      ]
    },
    "ItemDto": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "position": {
          "$ref": "#/$defs/Position"
        },
        "quantity": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "kindId",
        "position",
        "quantity"
      ]
    },
    "PlayerDto": {
      "type": "object",
      "properties": {
        "hp": {
          "type": "integer",
          "format": "int32"
        },
        "id": {
          "type": "string"
        },
        "kindId": {
          "type": "string"
        },
        "maxHp": {
          "type": "integer",
          "format": "int32"
        },
        "position": {
          "$ref": "#/$defs/Position"
        }
      },
      "required": [
        "id",
        "kindId",
        "position",
        "hp",
        "maxHp"
      ]
    },
    "Position": {
      "type": "object",
      "properties": {
        "x": {
          "type": "integer",
          "format": "int32"
        },
        "y": {
          "type": "integer",
          "format": "int32"
        }
      },
      "required": [
        "x",
        "y"
      ]
    },
    "VisibilityState": {
      "type": "string",
      "enum": [
        "visible",
        "remembered",
        "hidden"
      ]
    }
  }
}
