{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RoguelikeFansBand Rewrite",
  "version": "0.1.0",
  "identifier": "io.github.unclefvcker.rfb-rewrite",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RoguelikeFansBand Rewrite",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis"
  }
}
