{
  "$schema": "https://raw.githubusercontent.com/UncleFvcker/RoguelikeFansBand-Rewrite/main/schemas/content-v1/vault.schema.json",
  "formatVersion": 1,
  "id": "demo.vault.resonance-spindle",
  "nameKey": "vault-demo-resonance-spindle-name",
  "themeId": "demo.theme.resonance-deeps",
  "width": 3,
  "height": 4,
  "baseTerrainId": "demo.terrain.resonant-floor",
  "entrancePosition": { "x": 1, "y": 0 },
  "transforms": [
    "identity",
    "rotate90",
    "rotate180",
    "rotate270",
    "mirror-horizontal",
    "mirror-vertical",
    "mirror-main-diagonal",
    "mirror-anti-diagonal"
  ],
  "terrainOverrides": [
    {
      "terrainId": "demo.terrain.door-secret",
      "positions": [{ "x": 1, "y": 0 }]
    },
    {
      "terrainId": "demo.terrain.wall",
      "positions": [
        { "x": 0, "y": 0 }, { "x": 2, "y": 0 },
        { "x": 0, "y": 1 }, { "x": 2, "y": 1 },
        { "x": 0, "y": 2 }, { "x": 2, "y": 2 },
        { "x": 0, "y": 3 }, { "x": 1, "y": 3 }, { "x": 2, "y": 3 }
      ]
    }
  ],
  "encounterGroups": [
    {
      "id": "demo.vault-group.resonance-spindle-watch",
      "memberPositions": [{ "x": 1, "y": 2 }],
      "entries": [
        {
          "actorKindId": "demo.actor.resonant-warden",
          "weight": 1,
          "minDepth": 8,
          "maxDepth": 8
        }
      ]
    }
  ],
  "lootSpawns": [
    {
      "id": "demo.vault-loot.resonance-spindle-cache",
      "position": { "x": 1, "y": 1 },
      "lootTableId": "demo.loot-table.resonant-warden"
    }
  ]
}
