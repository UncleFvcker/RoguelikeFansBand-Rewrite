message-move-blocked = The structure ahead blocks your path.
message-combat-hit = You hit { $target } for { $damage } damage.
message-combat-slay = { $target } fades away.
message-item-pickup-success = You pick up { $target } ×{ $quantity }.
message-item-pickup-none = There is nothing here to pick up.
message-unknown-event = [{ $key }]
